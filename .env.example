# Configurazione Firebase per Gifty.
# Copia questo file in `.env` e inserisci i valori del TUO progetto Firebase
# (Console Firebase -> Impostazioni progetto -> Le tue app -> Aggiungi Firebase al tuo web).
#
# NOTA: le Web API key di Firebase sono pubbliche per design (vengono spedite al
# browser). La sicurezza NON dipende dalla loro segretezza, ma dalle regole del
# database (vedi database.rules.json). Per questo `.env` e' in .gitignore.

REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_DATABASE_URL=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
